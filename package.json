{
  "name": "@argus/enterprise-agent",
  "version": "1.0.0",
  "description": "ARGUS Enterprise Autonomy Agent - Built with OpenRouter SDK, LangChain patterns, and Ollama support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start:headless": "node dist/headless.js",
    "start:ollama": "node dist/ollama-example.js",
    "studio": "npx @langchain/langgraph-cli dev",
    "studio:tunnel": "npx @langchain/langgraph-cli dev --tunnel",
    "lint": "eslint src/**/*.ts",
    "test": "vitest"
  },
  "keywords": [
    "ai-agent",
    "enterprise",
    "autonomy",
    "openrouter",
    "langchain",
    "ollama",
    "multi-agent",
    "coordination"
  ],
  "author": "ARGUS Enterprise Team",
  "license": "MIT",
  "dependencies": {
    "@openrouter/sdk": "^1.0.0",
    "eventemitter3": "^5.0.1",
    "zod": "^3.22.4",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
