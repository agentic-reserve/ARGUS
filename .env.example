# ARGUS Enterprise Agent Environment Configuration

# Required: OpenRouter API Key
# Get your key at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: Model Selection
# Use 'openrouter/auto' for automatic model selection
# Or specify: 'anthropic/claude-3.5-sonnet', 'openai/gpt-4o', etc.
ARGUS_MODEL=openrouter/auto

# Optional: Configuration
ARGUS_MAX_STEPS=10
ARGUS_ENTERPRISE_MODE=true

# Optional: Ollama Configuration (for local models)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# Optional: Logging
LOG_LEVEL=info
