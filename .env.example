# ARGUS Enterprise Agent Environment Configuration

# Solana Blockchain
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_WALLET_KEY=your-wallet-private-key-here

# Supabase Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# Dataset Path
DATASET_PATH=./dataset

# LangSmith (optional)
LANGSMITH_API_KEY=your-langsmith-key-here
LANGSMITH_PROJECT=argus-agent

# OpenRouter (when available)
OPENROUTER_API_KEY=your-openrouter-key-here
ARGUS_MODEL=openrouter/auto

# Optional: Configuration
ARGUS_MAX_STEPS=10
ARGUS_ENTERPRISE_MODE=true

# Optional: Ollama Configuration (for local models)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# Optional: Logging
LOG_LEVEL=info
