# Root .gitignore for /Users/macbook/colo/
# Protects all sensitive files across the entire workspace

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Secrets and keys
secrets/
*.key
*.pem
*.cert
*.p12
*.pfx

# Dependencies
node_modules/
.pnp
.pnp.js
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
build/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
lerna-debug.log*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Temporary files
.cache/
temp/
tmp/
*.tmp

# Coverage and test reports
coverage/
.nyc_output/

# Misc
.pnpm-store/
*.pid
*.seed
*.pid.lock
